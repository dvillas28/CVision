generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DELETED
}

enum CareerStage {
  STUDENT
  RECENT_GRADUATE
  JUNIOR
  PROFESSIONAL
}

enum ConsentType {
  TERMS
  PRIVACY_POLICY
  AI_PROCESSING
}

enum CVStatus {
  DRAFT
  COMPLETED
  ARCHIVED
  DELETED
}

enum CVSectionType {
  PERSONAL_INFO
  SUMMARY
  EDUCATION
  EXPERIENCE
  SKILLS
  CERTIFICATIONS
  PROJECTS
  LANGUAGES
  ADDITIONAL
}

enum PromptType {
  SECTION_OPTIMIZER
  FULL_CV_REVIEW
  ATS_ANALYZER
  KEYWORD_EXTRACTOR
}

enum PromptStatus {
  DRAFT
  TESTING
  ACTIVE
  ARCHIVED
}

enum AiRunStatus {
  SUCCESS
  FAILED
  TIMEOUT
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  EDITED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StorageProvider {
  S3
  CLOUDINARY
  LOCAL
}

enum NotificationType {
  SYSTEM
  AI
  ATS
  PDF
  ADMIN
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique @db.VarChar(255)
  passwordHash    String     @db.VarChar(255)
  name            String     @db.VarChar(160)
  role            UserRole   @default(USER)
  status          UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  profile        UserProfile?
  consents       UserConsent[]
  refreshTokens  RefreshToken[]
  emailTokens    EmailVerificationToken[]
  passwordTokens PasswordResetToken[]
  cvs            CV[]
  aiRuns         AiRun[]
  notifications  Notification[]
  auditLogs      AuditLog[]               @relation("ActorAuditLogs")
  fileAssets     FileAsset[]              @relation("UserFileAssets")
  metricEvents   MetricEvent[]
  createdPrompts AiPrompt[]               @relation("PromptCreator")

  @@index([role])
  @@index([status])
  @@index([deletedAt])
}

model UserProfile {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @unique @db.Uuid
  phone          String?      @db.VarChar(40)
  location       String?      @db.VarChar(120)
  linkedinUrl    String?      @db.VarChar(255)
  avatarUrl      String?      @db.VarChar(500)
  careerStage    CareerStage?
  targetRole     String?      @db.VarChar(160)
  targetIndustry String?      @db.VarChar(160)
  preferences    Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserConsent {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @db.Uuid
  type       ConsentType
  version    String      @db.VarChar(40)
  accepted   Boolean     @default(false)
  acceptedAt DateTime?
  ipAddress  String?     @db.VarChar(80)
  userAgent  String?     @db.VarChar(500)
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, version])
  @@index([userId, type])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Template {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(120)
  category    String   @db.VarChar(80)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true)
  config      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cvs      CV[]
  versions TemplateVersion[]

  @@index([isActive])
  @@index([category])
}

model TemplateVersion {
  id            String   @id @default(uuid()) @db.Uuid
  templateId    String   @db.Uuid
  versionNumber Int
  config        Json
  createdAt     DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, versionNumber])
}

model CV {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  templateId     String?   @db.Uuid
  title          String    @db.VarChar(160)
  status         CVStatus  @default(DRAFT)
  isPrimary      Boolean   @default(false)
  atsScore       Int?
  targetRole     String?   @db.VarChar(160)
  targetIndustry String?   @db.VarChar(160)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template      Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sections      CVSection[]
  versions      CVVersion[]
  atsReports    AtsReport[]
  aiRuns        AiRun[]
  aiSuggestions AiSuggestion[]
  pdfDocuments  PdfDocument[]
  metricEvents  MetricEvent[]

  @@index([userId])
  @@unique([userId, title])
  @@index([templateId])
  @@index([status])
  @@index([deletedAt])
}

model CVSection {
  id         String        @id @default(uuid()) @db.Uuid
  cvId       String        @db.Uuid
  type       CVSectionType
  order      Int
  isRequired Boolean       @default(false)
  content    Json
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  cv            CV             @relation(fields: [cvId], references: [id], onDelete: Cascade)
  aiSuggestions AiSuggestion[]

  @@unique([cvId, order])
  @@unique([cvId, type])
}

model CVVersion {
  id            String   @id @default(uuid()) @db.Uuid
  cvId          String   @db.Uuid
  versionNumber Int
  snapshot      Json
  atsScore      Int?
  changeReason  String?  @db.VarChar(255)
  createdAt     DateTime @default(now())

  cv           CV            @relation(fields: [cvId], references: [id], onDelete: Cascade)
  pdfDocuments PdfDocument[]

  @@unique([cvId, versionNumber])
  @@index([cvId])
}

model AtsReport {
  id              String   @id @default(uuid()) @db.Uuid
  cvId            String   @db.Uuid
  score           Int
  keywords        Json
  issues          Json
  recommendations Json
  createdAt       DateTime @default(now())

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@index([score])
}

model AiPrompt {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @db.VarChar(140)
  type        PromptType
  content     String
  version     Int
  status      PromptStatus @default(DRAFT)
  createdById String?      @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  createdBy User?   @relation("PromptCreator", fields: [createdById], references: [id], onDelete: SetNull)
  aiRuns    AiRun[]

  @@unique([name, version])
  @@index([type, status])
}

model AiRun {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @db.Uuid
  cvId         String?     @db.Uuid
  promptId     String?     @db.Uuid
  model        String      @db.VarChar(120)
  inputTokens  Int?
  outputTokens Int?
  latencyMs    Int?
  status       AiRunStatus
  errorMessage String?
  metadata     Json?
  createdAt    DateTime    @default(now())

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cv          CV?            @relation(fields: [cvId], references: [id], onDelete: SetNull)
  prompt      AiPrompt?      @relation(fields: [promptId], references: [id], onDelete: SetNull)
  suggestions AiSuggestion[]

  @@index([userId])
  @@index([cvId])
  @@index([promptId])
  @@index([status])
  @@index([createdAt])
}

model AiSuggestion {
  id            String           @id @default(uuid()) @db.Uuid
  aiRunId       String           @db.Uuid
  cvId          String           @db.Uuid
  sectionId     String?          @db.Uuid
  status        SuggestionStatus @default(PENDING)
  severity      Severity         @default(MEDIUM)
  title         String           @db.VarChar(180)
  originalText  String?
  suggestedText String?
  explanation   String?
  createdAt     DateTime         @default(now())
  appliedAt     DateTime?

  aiRun   AiRun      @relation(fields: [aiRunId], references: [id], onDelete: Cascade)
  cv      CV         @relation(fields: [cvId], references: [id], onDelete: Cascade)
  section CVSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([aiRunId])
  @@index([cvId])
  @@index([sectionId])
  @@index([status])
}

model PdfDocument {
  id          String   @id @default(uuid()) @db.Uuid
  cvId        String   @db.Uuid
  versionId   String   @db.Uuid
  fileName    String   @db.VarChar(180)
  fileUrl     String   @db.VarChar(500)
  storageKey  String   @db.VarChar(255)
  sizeBytes   Int?
  generatedAt DateTime @default(now())

  cv      CV        @relation(fields: [cvId], references: [id], onDelete: Cascade)
  version CVVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@index([versionId])
}

model FileAsset {
  id         String          @id @default(uuid()) @db.Uuid
  ownerId    String?         @db.Uuid
  provider   StorageProvider
  url        String          @db.VarChar(500)
  storageKey String          @db.VarChar(255)
  mimeType   String          @db.VarChar(120)
  sizeBytes  Int?
  metadata   Json?
  createdAt  DateTime        @default(now())
  deletedAt  DateTime?

  owner User? @relation("UserFileAssets", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([provider])
  @@index([deletedAt])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(160)
  message   String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([type])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  action     String   @db.VarChar(120)
  entityType String   @db.VarChar(120)
  entityId   String?  @db.Uuid
  metadata   Json?
  ipAddress  String?  @db.VarChar(80)
  userAgent  String?  @db.VarChar(500)
  createdAt  DateTime @default(now())

  actor User? @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model MetricEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  cvId      String?  @db.Uuid
  eventName String   @db.VarChar(120)
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  cv   CV?   @relation(fields: [cvId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([cvId])
  @@index([eventName])
  @@index([createdAt])
}
